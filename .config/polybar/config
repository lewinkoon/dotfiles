[global/wm]
include-file = ~/.config/polybar/colors.ini

[bar/default]
monitor = eDP-1-1
override-redirect = false
wm-restack = bspwm
bottom = false
fixed-center = true
width = 99%
height = 50
line-size = 3

module-margin-left = 2
module-margin-right = 2

enable-ipc = true

background = ${color.bg}
foreground = ${color.fg}

font-0 = NotoSans:size=14;2
font-1 = Font Awesome 5 Free Solid:size=16;3
font-2 = Font Awesome 5 Brands:size=16;4
font-3 = Font Awesome 5 Free Regular:size=20;3

scroll-up = i3wm-wsnext
scroll-down = i3wm-wsprev

modules-left = bspwm
modules-center = date
modules-right = ethernet wifi pulseaudio cpu battery

[settings]
throttle-output = 5
throttle-output-for = 10
throttle-input-for = 30

[module/backlight]
type = internal/backlight
card = intel_backlight

format = <ramp> <label>
label = %percentage%%

ramp-0 = ’ćÄ
ramp-1 = ’åÆ
ramp-2 = ’äæ

[module/battery]
type = internal/battery
full-at = 96
battery = BAT0
adapter = AC0

format-charging = <animation-charging> <label-charging>
format-discharging = <label-discharging>
label-charging = %percentage%%
label-discharging = Discharging %percentage%%
label-full = ’ēĆ  Full

animation-charging-0 = ’ēä
animation-charging-1 = ’ēā
animation-charging-2 = ’ēé
animation-charging-3 = ’ēü
animation-charging-4 = ’ēĆ
animation-charging-framerate = 750

[module/cpu]
type = internal/cpu
interval = 1
format = <label>
label = ’ŗø  %percentage%%

[module/memory]
type = internal/memory
interval = 3
format = ’öĖ <label>
label = %percentage_used%%

[module/mpd]
type = internal/mpd
host = localhost
port = 6600
interval = 2

format-online = <icon-prev>  <toggle>  <icon-next>  <label-song>
icon-play = ’ģä
icon-pause = ’Ŗŗ
icon-stop = ’ŖŹ
icon-prev = ’äĘ
icon-next = ’äĖ

[module/ethernet]
type = internal/network
interface = enp3s0f1
interval = 3.0
format-connected = ’ø┐  <label-connected>
label-connected = %essid%

[module/wifi]
type = internal/network
interface = wlp2s0
interval = 3.0
format-connected = ’ć½  <label-connected>
label-connected = %essid%

[module/pulseaudio]
type = internal/pulseaudio
sink = @DEFAULT_SINK@
use-ui-max = true
interval = 5

format-volume = <ramp-volume>  <label-volume>
label-muted = ’Ü®  muted
ramp-volume-0 = ’Ć”
ramp-volume-1 = ’Ć¦
ramp-volume-2 = ’Ć©

[module/date]
type = internal/date
interval = 1.0
time = %a %d %b, %H:%M
time-alt = %H:%M:%S

format = <label>
format-background = ${color.bg}
format-foreground = ${color.fg}
label = %time%
label-foreground = ${color.fg}

[module/i3]
type = internal/i3
pin-workspaces = true
strip-wsnumbers = true
index-sort = true
enable-click = true
enable-scroll = true
fuzzy-match = false

ws-icon-0 = 1:terminal;’äĀ
ws-icon-1 = 2:files;’ü╝
ws-icon-2 = 3:browser;’ē©
ws-icon-3 = 4:mail;’āĀ
ws-icon-4 = 5:chat;’éå
ws-icon-5 = 6:music;’Ćü
ws-icon-6 = 7:news;’é×
ws-icon-7 = 8:calendar;’ä│

format = <label-state>

label-focused = %icon%

label-unfocused = %icon%
label-unfocused-foreground = ${color.ac}
label-unfocused-background = ${color.bg}

label-visible = %icon%

label-urgent = %icon%
label-urgent-foreground = ${color.red}
label-urgent-background = ${color.bg}

label-focused-padding = 2
label-visible-padding = 2
label-urgent-padding = 2
label-unfocused-padding = 2

[module/bspwm]
type = internal/bspwm

fuzzy-match = false

ws-icon-0 = I;’äĀ
ws-icon-1 = II;’ü╝
ws-icon-2 = III;’×ó
ws-icon-3 = IV;’āĀ
ws-icon-4 = V;’éå
ws-icon-5 = VI;’Ćü
ws-icon-6 = VII;’é×

format = <label-state>

label-focused = %icon%
label-focused-overline = ${color.fg}
label-focused-padding = 4

label-occupied = %icon%
label-occupied-foreground = ${color.fg}
label-occupied-background = ${color.bg}
label-occupied-padding = 4

label-urgent = %icon%
label-urgent-foreground = ${color.red}
label-urgent-background = ${color.bg}
label-urgent-padding = 4

label-empty = %icon%
label-empty-foreground = ${color.ac}
label-empty-background = ${color.bg}
label-empty-padding = 4


